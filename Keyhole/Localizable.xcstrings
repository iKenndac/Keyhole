    "PermissionDoctorAccessibilityText" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Keyhole needs the accessibility permission in order to listen for presses of your media keys. You can enable this permission in **Privacy & Security** → **Accessibility** in System Settings.\n\n**Note:** You may need to quit and restart Keyhole after granting permission for keypresses to be detected correctly."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Keyhole a besoin de l’autorisation d’accessibilité pour détecter les pressions sur les touches multimédia de votre clavier. Vous pouvez activer cette autorisation dans **Réglages Système** → **Confidentialité et sécurité** → **Accessibilité**.\n\n**Remarque** : Il peut être nécessaire de quitter puis de relancer Keyhole après avoir accordé l’autorisation afin que les pressions sur les touches soient correctement détectées."
          }
        }
      }
    },
    "PermissionDoctorAllOKAlertMessage" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You can access Keyhole's settings by clicking the Keyhole icon in your menu bar."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous pouvez accéder aux réglages de Keyhole en cliquant sur son icône dans la barre des menus."
          }
        }
      }
    },
    "PermissionDoctorAllOKAlertTitle" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You’re all set!"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tout est prêt !"
          }
        }
      }
    },
    "PermissionDoctorAppAutomationText" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Keyhole needs permission to automate %1$(appName)@ in order to send commands to it. You can enable this permission in **Privacy & Security** → **Automation** → **Keyhole** in System Settings."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Keyhole a besoin de l’autorisation d’automatisation pour contrôler %1$(appName)@ et lui envoyer des commandes. Vous pouvez activer cette autorisation dans **Réglages Système** → **Confidentialité et sécurité** → **Automatisation** → **Keyhole**."
          }
        }
      }
    },
    "PermissionDoctorGrantPermissionButtonTitle" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Grant Permission…"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Accorder l’autorisation"
          }
        }
      }
    },
    "PermissionDoctorIntroText" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Welcome! Keyhole puts you in control of your media keys by making sure they get delivered to the app you *want* them to.\n\nIn order to work correctly, Keyhole needs some permissions from macOS."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bienvenue ! Keyhole vous permet de garder le contrôle de vos touches multimédia en veillant à ce qu’elles soient envoyées à l’app de **votre choix**.\n\nPour fonctionner correctement, Keyhole a besoin de certaines autorisations de macOS."
          }
        }
      }
    },
    "PermissionDoctorMissingPermissionAlertConfirmationButtonTitle" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "I Understand"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Je comprends"
          }
        }
      }
    },
    "PermissionDoctorMissingPermissionAlertMessage" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Without permission to use Accessibility and to automate at least one media player, Keyhole won't work correctly.\n\nYou can grant these permissions later from the Keyhole icon in your menu bar."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sans l’autorisation d’accessibilité et l’autorisation d’automatiser au moins un lecteur multimédia, Keyhole ne pourra pas fonctionner correctement.\n\nVous pourrez accorder ces autorisations ultérieurement depuis l’icône Keyhole dans la barre des menus."
          }
        }
      }
    },
